# Application
APP_ENV=development
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000

# Model paths (overrides config.yaml if set)
MODEL_PATH=artifacts/models/xgb_calibrated.joblib
SCALER_PATH=artifacts/models/scaler.joblib

# MLflow (optional)
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=risk-scoring

# Database (optional — for audit logging)
DATABASE_URL=postgresql://user:password@localhost:5432/risk_scoring
